<application xmlns="http://schemas.taskletfactory.com/MobileWMS/Application"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://schemas.taskletfactory.com/MobileWMS/Application http://schemas.taskletfactory.com/MobileWMS/Application.xsd">

    <!--
        Template: Unplanned with no user-fillable header fields and no steps — action on an existing page.

        Flow: Action triggered from a parent page → header shows a context field and auto-accepts immediately →
              business logic reads context values from the calling page (no user input collected).

        The header has one locked, optional context field that auto-accepts on open without user interaction.
        It displays a context value from the calling page (e.g. location, bin) so the user can see their context.
        Rename "MyContext" to the context value key you want to display. See the AL codeunit for the field definition.

        This variant only makes practical sense as an action on an existing page (not in the Main Menu),
        because without user input it relies entirely on context values passed from the calling page.
        Context values contain the data of the currently selected row on the parent page
        (e.g. document number, line number, item, location) and are read via GetContextValue() in AL.

        Replace all occurrences of "MyUnplannedOnlyContext", "MY_UNPLANNED_FOUR_TITLE", and "MY_UNPLANNED_FOUR"
        with names that reflect your customization. Replace "myicon" with the icon id for your function.
    -->

    <pages>
        <!--
            New UnplannedItemRegistration page — locked context field in header, no steps.
              - tweak="Append"                    : registers as a new page without replacing existing ones
              - useRegistrationCollector="false"  : no step collection — business logic fires immediately after header
              - configurationKey                  : references the header configuration defined in AL via
                                                    OnGetReferenceData_OnAddHeaderConfigurations
              - automaticAcceptOnOpen="true"      : the header auto-accepts on open without user interaction
              - type (on configuration)           : registration type key — must match _RegistrationType in
                                                    OnPostAdhocRegistrationOnCustomRegistrationType in AL
        -->
        <page tweak="Append" id="MyUnplannedOnlyContext" type="UnplannedItemRegistration" icon="myicon">
            <title defaultValue="@{MY_UNPLANNED_FOUR_TITLE}" />
            <unplannedItemRegistrationConfiguration type="MyUnplannedOnlyContext" useRegistrationCollector="false">
                <header configurationKey="MyUnplannedOnlyContext" automaticAcceptOnOpen="true" />
            </unplannedItemRegistrationConfiguration>
        </page>

        <!--
            Adds this page as an action on an existing page.
            Replace "ExistingPage" with the id of the page where you want the action to appear
            (e.g. "PickLines", "ReceiveLines"). Must NOT be a page of type UnplannedItemRegistration.
              - title                        : the shorter label shown in the action list (uses a separate message key from the page title)
              - tweak="Append" on <actions>  : appends to the existing action list
              - returnTransfer               : refreshes the parent page after a successful registration
        -->
        <page id="Receive">
            <actions>
                <open tweak="Append" id="MyUnplannedOnlyContext" title="@{MY_UNPLANNED_FOUR}" icon="myicon">
                    <returnTransfer property="UnplannedItemRegistrationCompleted" to="RefreshOnResume" />
                </open>
            </actions>
        </page>
    </pages>

</application>
