<!--
    This tweak includes two main parts:
    - A new page:
        <page>
          - tweak="Append"                      : registers as a new page without replacing existing ones
          - id                                  : unique identifier for this page
          - type="UnplannedItemRegistration"    : freestanding registration, not tied to a document/order
          - icon                                : id of the icon shown for the page
        <title>
          - defaultValue                        : page title shown on the device (placeholder or hardcoded string)
        <unplannedItemRegistrationConfiguration>
          - type                                : registration type key — must match _RegistrationType in AL
          - useRegistrationCollector="true"     : steps are fetched after the header is accepted
        <header>
          - configurationKey                    : identifies which header fields to load — must match the key in AL
          - automaticAcceptOnOpen="true"        : the header auto-accepts on open without user interaction

    - A new action on the PickLines page:
        <page>
          - id               : identifier for the page to which the action is added (in this case, the built-in PickLines page)
        <open>
          - tweak="Append"   : appends the action to the existing actions list on the page
          - id               : must match the id of the page to open
          - title            : label shown for the action in the menu
          - icon             : id of the icon shown for the action
        <returnTransfer>
          - property         : the value/state to read from the opened page when returning
          - to               : where to apply that value on the parent page
                               e.g. property="UnplannedItemRegistrationCompleted" to="RefreshOnResume" refreshes
                               the parent page when returning, if the unplanned page performed a successful post
        
        In this example the page title and action title use placeholder @{UNABLE_TO_PICK_TITLE} to be able to support multiple languages.
        If you are only using one language, you can replace the placeholder with a hardcoded string.
        The placeholder is resolved by a Mobile Message record with the same key as the placeholder (without the @{}).
        Translations are supported by providing a message for each language code.
-->
<application xmlns="http://schemas.taskletfactory.com/MobileWMS/Application" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://schemas.taskletfactory.com/MobileWMS/Application http://schemas.taskletfactory.com/MobileWMS/Application.xsd">
    <pages>
        <page tweak="Append" id="UnableToPick" type="UnplannedItemRegistration" icon="mainmenunegativeadjustment">
            <title defaultValue="@{UNABLE_TO_PICK_TITLE}" />
            <unplannedItemRegistrationConfiguration type="UnableToPick" useRegistrationCollector="true">
                <header configurationKey="UnableToPick" automaticAcceptOnOpen="true" />
            </unplannedItemRegistrationConfiguration>
        </page>
        <page id="PickLines">
            <actions>
                <open tweak="Append" id="UnableToPick" title="@{UNABLE_TO_PICK_TITLE}" icon="mainmenunegativeadjustment">
                    <returnTransfer property="UnplannedItemRegistrationCompleted" to="RefreshOnResume" />
                </open>
            </actions>
        </page>
    </pages>
</application>